# Copy to backend/.env and fill in values. Never commit .env.

FLASK_ENV=development
# Required outside local play — set a long random value in any shared/staging/prod env.
# Production refuses to start if this is still the default below.
SECRET_KEY=dev-secret-change-in-production

# SQLite path. Local default is fine; on Render use the persistent disk, e.g.:
# DATABASE_PATH=/var/data/app.db
DATABASE_PATH=backend/instance/app.db

# Comma-separated Vite (or other) origins allowed for credentialed CORS.
# Production: set to your Vercel origin(s), e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Provider selectors (swap implementations without code changes)
# prices: coingecko | static
# news: rss | cryptopanic | static
# insight: gemini | template
# meme: reddit_gemini | static
# Use static (+ template insight) for offline / Playwright e2e.
PRICE_PROVIDER=coingecko
NEWS_PROVIDER=rss
AI_PROVIDER=gemini
MEME_PROVIDER=reddit_gemini

PROVIDER_HTTP_TIMEOUT=5
PROVIDER_CACHE_TTL=300

# Free API keys (leave blank to exercise fallbacks / alternate providers)
# CRYPTOPANIC_API_KEY only needed when NEWS_PROVIDER=cryptopanic
CRYPTOPANIC_API_KEY=
GEMINI_API_KEY=
# Prefer a current free-tier alias; gemini-2.0-flash often returns 429 with limit:0.
GEMINI_MODEL=gemini-flash-lite-latest

# CoinGecko (optional — keyless public API works; demo/pro raise rate limits)
COINGECKO_DEMO_API_KEY=
COINGECKO_PRO_API_KEY=
COINGECKO_USER_AGENT=AICryptoAdvisor/0.1 (educational; contact: local-dev)

# Reddit meme discovery (keyless Atom RSS — public .json returns 403)
# Prefer a single sub; extra subs are fallback-only and burn anonymous rate limits.
REDDIT_MEME_SUBREDDITS=cryptocurrencymemes
REDDIT_USER_AGENT=AICryptoAdvisor/0.1 (educational; contact: local-dev)
