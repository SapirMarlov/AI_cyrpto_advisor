# Local Vite: absolute Flask origin (cross-origin + CORS).
VITE_API_BASE_URL=http://127.0.0.1:5000

# Production (Vercel): leave empty so the SPA calls /api/... on the same origin.
# Vercel rewrites /api to Render; session cookies stay first-party (SameSite=Lax).
# Never point this at https://….onrender.com for cookie auth.
# VITE_API_BASE_URL=
