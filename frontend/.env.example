# Local Vite: leave empty so the SPA calls /api/... on the same origin.
# vite.config.ts proxies /api → http://127.0.0.1:5000 (Flask).
# Session cookies stay first-party (SameSite=Lax) on both localhost and 127.0.0.1.
VITE_API_BASE_URL=

# Production (Vercel): also leave empty. Vercel rewrites /api to Render.
# Never point this at https://….onrender.com for cookie auth.
# VITE_API_BASE_URL=
